{
  "manifest_version": 2,
  "id": "khIqwq.owner_auth_plugin",
  "name": "主人身份验证插件 (Owner Authentication Plugin)",
  "version": "2.1.0",
  "description": "为麦麦机器人提供 QQ 身份验证功能，基于 MaiBot 1.0 Hook 在回复前注入身份提示词，支持动态用户列表配置。",
  "author": {
    "name": "风花叶",
    "url": "https://github.com/khiqwq"
  },
  "license": "GPL-3.0-or-later",
  "urls": {
    "repository": "https://github.com/khiqwq/owner_auth_plugin",
    "homepage": "https://github.com/khiqwq/owner_auth_plugin",
    "documentation": "https://github.com/khiqwq/owner_auth_plugin#readme",
    "issues": "https://github.com/khiqwq/owner_auth_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "config.get",
    "send.command"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  },
  "plugin_type": "extension"
}
