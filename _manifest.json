{
  "manifest_version": 2,
  "id": "khiqwq.owner_auth_plugin",
  "version": "2.1.0",
  "name": "用户身份验证插件",
  "description": "通过 QQ 号精确验证发言者身份，在麦麦回复前注入用户/非用户身份提示词。用「用户数量控制」数字生成 N 个用户槽位，每个用户独立 QQ/昵称/限制群聊/多行模板，基于官方回复钩子实现，无 monkey-patch、无全局缓存，兼容 Windows 与 Linux 部署。",
  "author": {
    "name": "风花叶",
    "url": "https://github.com/khiqwq"
  },
  "license": "GPL-3.0-or-later",
  "urls": {
    "repository": "https://github.com/khiqwq/owner_auth_plugin",
    "homepage": "https://github.com/khiqwq/owner_auth_plugin",
    "issues": "https://github.com/khiqwq/owner_auth_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "message.get_by_id",
    "config.get",
    "send.text"
  ],
  "plugin_type": "extension",
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  }
}
